        "options": {}
      },
      "id": "wf06-request",
      "name": "POST Tarefa",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 300],
      "notes": "Cria tarefa automática no CRM vinculada ao lead."
    }
  ],
  "connections": {
    "Trigger": {
      "main": [
        [{ "node": "POST Tarefa", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": { "executionOrder": "v1" }
