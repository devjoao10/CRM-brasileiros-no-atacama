{
  "name": "WF-06 Tool Criar Tarefa",
  "nodes": [
    {
      "parameters": {},
      "id": "wf06-trigger",
      "name": "Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [220, 300]
    },
    {
      "parameters": {
        "method": "POST",
