# ====================================
# CRM Brasileiros no Atacama - .env
# ====================================

# Ambiente (development | production)
ENVIRONMENT=production

# Segurança
SECRET_KEY=gere_com_python_-c_import_secrets_print_secrets_token_urlsafe_64
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ====================================
# Banco de Dados — PostgreSQL
# ====================================

# Owner do banco (usado pelo docker-compose e pela app para criar tabelas)
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=SENHA_FORTE_OWNER

# User read-only (criado automaticamente — usado pela IA, APENAS SELECT)
CRM_READONLY_PASSWORD=SENHA_FORTE_READONLY

# URLs de conexão (geradas pelo docker-compose, não precisa mudar)
# DATABASE_URL=postgresql://crm_user:SENHA@postgres:5432/crm_atacama
# DATABASE_READONLY_URL=postgresql://crm_readonly:SENHA@postgres:5432/crm_atacama

# Para dev local (SQLite — descomentar e comentar as de cima):
# DATABASE_URL=sqlite:///./crm_atacama.db

# ====================================
# Admin / Seed
# ====================================
# Controla se o admin inicial é criado no startup do CRM.
# Em dev: defina como true e preencha email/senha.
# Em prod: defina como false (ou não defina ADMIN_INITIAL_PASSWORD).
SEED_INITIAL_ADMIN=true
ADMIN_INITIAL_EMAIL=admin@brasileirosnoatacama.com
ADMIN_INITIAL_PASSWORD=TROQUE_ESTA_SENHA

# Controla seed de dados de dev no Conversas (usuario, quick replies, templates, etc.)
CONVERSAS_SEED_DEV_DATA=true
CONVERSAS_DEV_EMAIL=admin@brasileirosnoatacama.com
CONVERSAS_DEV_PASSWORD=TROQUE_ESTA_SENHA

# Diretorio do espelho local de midia do Conversas (OPS-CONV-MEDIA-01).
# Em producao o docker-compose fixa /app/data/media (volume conversas_media);
# em dev local pode ficar vazio (default: conversas/uploads/media).
CONVERSAS_MEDIA_DIR=

# Domínio
APP_DOMAIN=https://crm.crmbrasileirosnoatacama.cloud

# ====================================
# E-mail (SMTP)
# ====================================
MAIL_USERNAME=seu_email@empresa.com
MAIL_PASSWORD=sua_senha
MAIL_FROM=seu_email@empresa.com
MAIL_PORT=587
MAIL_SERVER=smtp.hostinger.com
MAIL_FROM_NAME=Brasileiros no Atacama

# ====================================
# APIs
# ====================================
GEMINI_API_KEY=sua_chave_gemini

# ====================================
# Autenticação interna da IA (Perpétua) — PERPETUA-INTERNAL-AUTH-01
# ====================================
# Segredo BACKEND-ONLY. Permite que a Perpétua chame as rotas internas /api/ em
# nome do usuário logado (HMAC-SHA256), sem exigir que cada usuário gere uma API
# Key manualmente. NUNCA exponha no frontend. Sem este valor, as ferramentas
# internas da IA ficam desativadas (a IA ainda responde e faz SELECTs).
# Gere com:  openssl rand -base64 32
INTERNAL_AI_AUTH_SECRET=gere_com_openssl_rand_base64_32
# Janela de tolerância (segundos) do timestamp assinado (proteção contra replay).
INTERNAL_AI_AUTH_MAX_SKEW_SECONDS=300

# ====================================
# N8N
# ====================================
N8N_HOST=SEU_IP_OU_DOMINIO
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://SEU_IP_OU_DOMINIO:5678/

# ====================================
# Meta Cloud API (WhatsApp Business)
# ====================================
META_ACCESS_TOKEN=EAAxxxx_seu_token_meta
META_PHONE_NUMBER_ID=YOUR_META_PHONE_NUMBER_ID
META_VERIFY_TOKEN=um_token_secreto_para_webhook
META_WABA_ID=YOUR_META_WABA_ID
# App Secret do painel Meta for Developers → Seu app → Configurações → App Secret
# Usado para validar X-Hub-Signature-256 em cada POST do webhook
# OBRIGATÓRIO em produção — sem este valor o webhook rejeita todas as requisições
# NÃO confundir com META_VERIFY_TOKEN (usado apenas na verificação GET inicial)
META_APP_SECRET=

# WhatsApp do admin (para receber alertas dos workflows)
ADMIN_WHATSAPP=5551990119605

# ====================================
# Agente IA (Bia)
# ====================================
# Ativar o agente IA para responder automaticamente no WhatsApp
# Requer WF-10 ativo no N8N + credencial Gemini configurada
N8N_AGENT_ENABLED=false

# ====================================
# Segurança Extra
# ====================================
MAX_UPLOAD_SIZE_BYTES=10485760
API_KEY_EXPIRY_DAYS=0

# ---------------------------------------------------------------------------
# BIA-RAG-CONTEXT-01 / BIA-RAG-EMBEDDINGS-01 — serviço RAG interno da BIA
# ---------------------------------------------------------------------------
# Provedor de embeddings: "gemini" (produção, reusa GEMINI_API_KEY) ou
# "deterministic" (offline/testes). BIA_RAG_EMBEDDING_BACKEND é aceito como alias.
BIA_RAG_EMBEDDING_PROVIDER=gemini
# Embeddings Gemini (SDK google-genai). Defaults seguros — só sobrescrever se
# souber o que está fazendo. NÃO usar text-embedding-004 (descontinuado).
BIA_RAG_EMBEDDING_MODEL=gemini-embedding-001
BIA_RAG_EMBEDDING_DIMENSIONS=768
BIA_RAG_DOCUMENT_TASK_TYPE=RETRIEVAL_DOCUMENT
BIA_RAG_QUERY_TASK_TYPE=QUESTION_ANSWERING
# Fallback de task type de pergunta se a conta rejeitar QUESTION_ANSWERING.
BIA_RAG_QUERY_FALLBACK_TASK_TYPE=RETRIEVAL_QUERY
BIA_RAG_EMBEDDING_BATCH_SIZE=32
# Secret de autenticação interna do serviço RAG (header X-BIA-RAG-Token).
# Gere um valor forte, ex.: openssl rand -base64 32. NUNCA versione o valor real.
BIA_RAG_INTERNAL_SECRET=
